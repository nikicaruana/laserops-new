# Public site URL — used for canonical tags, sitemap, OG images
NEXT_PUBLIC_SITE_URL=https://laseropsmalta.com

# Google Tag Manager — leave blank to disable tracking entirely
# Format: GTM-XXXXXXX
NEXT_PUBLIC_GTM_ID=

