# Public site URL — used for canonical tags, sitemap, OG images
NEXT_PUBLIC_SITE_URL=https://laseropsmalta.com

# Google Tag Manager — leave blank to disable tracking entirely
# Format: GTM-XXXXXXX
NEXT_PUBLIC_GTM_ID=

# Cloudinary — powers the /gallery page.
# Create a free account at cloudinary.com, then find these under
# Settings → Access Keys. All three are required; missing any one
# disables the gallery (empty state shown instead of crashing).
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Future env vars (documented here for reference, not yet wired up):
# NEXT_PUBLIC_BOOKING_PROVIDER_URL=
# GOOGLE_SHEETS_ID=
# GOOGLE_SERVICE_ACCOUNT_EMAIL=
# GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=
